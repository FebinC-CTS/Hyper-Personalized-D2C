# Copy to .env.local and paste your Anthropic API key here.
#
# Important: this variable does NOT have a VITE_ prefix on purpose.
# Without VITE_, Vite will NOT bundle it into the browser. It's read
# at dev-server startup and injected server-side by the proxy defined
# in vite.config.ts (browser → Vite → Anthropic).
#
# Restart `npm run dev` after editing this file.
ANTHROPIC_API_KEY=sk-ant-...
